{
  "name": "konglish-ai",
  "version": "0.3.0",
  "description": "영어를 한국어 발음으로 바꿔주는 라이브러리",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "build:dict": "tsx src/pron/script/buildDictionary.ts",
    "merge:dict": "tsx src/pron/script/mergeDictionaries.ts",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "keywords": [
    "konglish",
    "hangul",
    "english",
    "transliteration",
    "g2p"
  ],
  "author": "sami9166",
  "dependencies": {
    "onnxruntime-node": "^1.24.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "^25.3.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
